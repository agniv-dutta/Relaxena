# Relaxena Backend Configuration

# App Settings
APP_NAME=Relaxena
ENVIRONMENT=development
DEBUG=true

# Secrets
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET_KEY=your-jwt-256bit-secret-key
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite+aiosqlite:///./relaxena.db

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost

# Groq AI (optional - https://console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# Weather API (optional)
OPENWEATHER_API_KEY=

# Sports Data API (optional)
SPORTSDATA_API_KEY=

# SMS Notifications (optional)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email
FROM_EMAIL=alerts@relaxena.io
